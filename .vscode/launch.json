{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OV10: Debug CLI",
      "type": "debugpy",
      "request": "launch",
      "module": "ov10.cli",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\.venv312\\Scripts\\python.exe"
    },
    {
      "name": "OV10: Debug Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\.venv312\\Scripts\\python.exe"
    },
    {
      "name": "OV10: Debug legacy main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\.venv312\\Scripts\\python.exe"
    }
  ]
}
